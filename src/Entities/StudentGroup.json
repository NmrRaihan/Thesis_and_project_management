{
  "name": "StudentGroup",
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string"
    },
    "group_name": {
      "type": "string"
    },
    "leader_student_id": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "student_id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["leader", "member"]
          }
        }
      }
    },
    "project_type": {
      "type": "string",
      "enum": [
        "thesis",
        "project",
        "undecided"
      ],
      "default": "undecided"
    },
    "field_of_interest": {
      "type": "string"
    },
    "assigned_teacher_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "forming",
        "active",
        "supervised",
        "completed"
      ],
      "default": "forming"
    }
  },
  "required": [
    "leader_student_id"
  ]
}