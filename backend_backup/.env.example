# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local MongoDB (for development)
MONGODB_URI=mongodb://localhost:27017/thesisHub

# MongoDB Atlas (for production) - Uncomment and configure for production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thesisHub?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate a new secret for production using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Admin Credentials (for initial setup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@thesisHub.com

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
